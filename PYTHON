@app.post("/upload", response_model=UploadResponse)
async def upload(files: List[UploadFile] = File(...)):
    if not files:
        raise HTTPException(status_code=400, detail="No files uploaded")

    uploaded = []
    total_chunks = 0

    for file in files:
        try:
            info = ingest_file(file)
            uploaded.append(info)
            total_chunks += int(info["chunks"])
        except HTTPException:
            raise
        except Exception as e:
            logger.exception("Upload failed for %s", file.filename)
            raise HTTPException(status_code=500, detail=f"Failed to process '{file.filename}': {str(e)}")

    return UploadResponse(uploaded_files=uploaded, total_chunks=total_chunks)


@app.post("/chat", response_model=ChatResponse)
async def chat(payload: ChatRequest):
    message = payload.message.strip()
    if not message:
        raise HTTPException(status_code=400, detail="Message cannot be empty")

    session_id, _ = get_session(payload.session_id)

    append_session_message(session_id, "user", message)

    session_context = build_session_context(session_id)
    search_query = message
    if session_context:
        search_query = f"{message}\n\nConversation context:\n{session_context}"

    retrieved, best_score = retrieve_relevant_chunks(search_query, top_k=TOP_K)
    confidence = estimate_confidence(best_score, retrieved)

    prompt_messages = build_prompt(message, retrieved, session_context)

    try:
        if confidence < 0.15:
            answer = "I could not find enough information in the uploaded documents."
        else:
            answer = call_llm(prompt_messages)
            if not answer:
                answer = "I could not find enough information in the uploaded documents."
    except Exception:
        logger.exception("LLM call failed")
        answer = fallback_answer(message, retrieved)

    append_session_message(session_id, "assistant", answer)

    return ChatResponse(
        session_id=session_id,
        answer=answer,
        sources=retrieved,
        confidence=confidence,
        timestamp=now_iso(),
    )


@app.get("/sessions/{session_id}")
def get_session_history(session_id: str):
    session = session_store.get(session_id)
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")
    return {
        "session_id": session_id,
        "created_at": session.get("created_at"),
        "updated_at": session.get("updated_at"),
        "messages": session.get("messages", []),
    }


@app.delete("/sessions/{session_id}")
def clear_session_history(session_id: str):
    with lock:
        if session_id in session_store:
            del session_store[session_id]
            return {"status": "deleted", "session_id": session_id}
    raise HTTPException(status_code=404, detail="Session not found")


