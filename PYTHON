def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def normalize_text(text: str) -> str:
    text = text.replace("\x00", " ")
    text = re.sub(r"\r\n", "\n", text)
    text = re.sub(r"[ \t]+", " ", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def safe_filename(name: str) -> str:
    name = Path(name).name
    name = re.sub(r"[^A-Za-z0-9._-]+", "_", name)
    return name[:180] if len(name) > 180 else name


def file_sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def text_hash(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8", errors="ignore")).hexdigest()


def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, chunk_overlap: int = CHUNK_OVERLAP) -> List[str]:
    text = normalize_text(text)
    if not text:
        return []

    paragraphs = re.split(r"\n\s*\n", text)
    chunks: List[str] = []
    current = ""

    def push_current() -> None:
        nonlocal current
        c = current.strip()
        if c:
            chunks.append(c)
        current = ""

    for para in paragraphs:
        para = para.strip()
        if not para:
            continue

        if len(para) > chunk_size:
            if current:
                push_current()
            start = 0
            while start < len(para):
                end = min(len(para), start + chunk_size)
                piece = para[start:end].strip()
                if piece:
                    chunks.append(piece)
                if end >= len(para):
                    break
                start = max(end - chunk_overlap, start + 1)
            continue

        prospective_len = len(current) + len(para) + (2 if current else 0)
        if prospective_len <= chunk_size:
            current = (current + "\n\n" + para).strip() if current else para
        else:
            if current:
                push_current()
            current = para

    if current:
        push_current()

    if not chunks:
        return [text[:chunk_size]]

    final_chunks = [chunks[0]]
    for chunk in chunks[1:]:
        prev = final_chunks[-1]
        if len(prev) < chunk_size // 2:
            final_chunks[-1] = (prev + "\n\n" + chunk)[:chunk_size]
        else:
            final_chunks.append(chunk)

    return [c.strip() for c in final_chunks if c.strip()]


def extract_text_from_pdf(path: Path) -> str:
    reader = PdfReader(str(path))
    parts = []
    for page in reader.pages:
        try:
            parts.append(page.extract_text() or "")
        except Exception:
            continue
    return normalize_text("\n".join(parts))


def extract_text_from_txt(path: Path) -> str:
    return normalize_text(path.read_text(encoding="utf-8", errors="ignore"))


def extract_text_from_docx(path: Path) -> str:
    doc = DocxDocument(str(path))
    paragraphs = [p.text for p in doc.paragraphs if p.text and p.text.strip()]
    return normalize_text("\n".join(paragraphs))


def extract_text(path: Path) -> str:
    ext = path.suffix.lower()
    if ext == ".pdf":
        return extract_text_from_pdf(path)
    if ext == ".txt":
        return extract_text_from_txt(path)
    if ext == ".docx":
        return extract_text_from_docx(path)
    raise HTTPException(status_code=400, detail=f"Unsupported file type: {ext}")


def embed_texts(texts: List[str]) -> np.ndarray:
    vectors = embedder.encode(
        texts,
        convert_to_numpy=True,
        normalize_embeddings=True,
        show_progress_bar=False,
    )
    if vectors.ndim == 1:
        vectors = np.expand_dims(vectors, axis=0)
    return vectors.astype(np.float32)


def add_chunks_to_vector_db(
    *,
    chunks: List[str],
    source_name: str,
    file_hash: str,
    file_path: str,
    file_type: str,
) -> int:
    if not chunks:
        return 0

    embeddings = embed_texts(chunks)
    ids = []
    metadatas = []
    documents = []

    for i, chunk in enumerate(chunks):
        chunk_id = f"{file_hash[:16]}_{i}_{text_hash(chunk)[:12]}"
        ids.append(chunk_id)
        metadatas.append(
            {
                "source_name": source_name,
                "file_hash": file_hash,
                "file_path": file_path,
                "file_type": file_type,
                "chunk_index": i,
                "timestamp": now_iso(),
            }
        )
        documents.append(chunk)

    collection.add(
        ids=ids,
        documents=documents,
        embeddings=embeddings.tolist(),
        metadatas=metadatas,
    )
    return len(chunks)


def retrieve_relevant_chunks(query: str, top_k: int = TOP_K) -> Tuple[List[Dict[str, Any]], float]:
    q_emb = embed_texts([query])[0].tolist()

    result = collection.query(
        query_embeddings=[q_emb],
        n_results=top_k,
        include=["documents", "metadatas", "distances"],
    )

    docs = result.get("documents", [[]])[0] or []
    metas = result.get("metadatas", [[]])[0] or []
    distances = result.get("distances", [[]])[0] or []

    sources = []
    best_score = 0.0

    for doc, meta, dist in zip(docs, metas, distances):
        score = max(0.0, min(1.0, 1.0 - float(dist)))
        best_score = max(best_score, score)
        sources.append(
            {
                "text": doc,
                "metadata": meta,
                "score": round(score, 4),
            }
        )

    return sources, round(best_score, 4)


def get_session(session_id: Optional[str]) -> Tuple[str, Dict[str, Any]]:
    with lock:
        if not session_id:
            session_id = str(uuid.uuid4())
        if session_id not in session_store:
            session_store[session_id] = {
                "messages": [],
                "created_at": now_iso(),
                "updated_at": now_iso(),
            }
        return session_id, session_store[session_id]


def append_session_message(session_id: str, role: str, content: str) -> None:
    with lock:
        session = session_store.setdefault(
            session_id,
            {"messages": [], "created_at": now_iso(), "updated_at": now_iso()},
        )
        session["messages"].append(
            {
                "role": role,
                "content": content,
                "timestamp": now_iso(),
            }
        )
        session["updated_at"] = now_iso()
        if len(session["messages"]) > MAX_SESSION_MESSAGES:
            session["messages"] = session["messages"][-MAX_SESSION_MESSAGES:]


def build_session_context(session_id: str) -> str:
    session = session_store.get(session_id, {})
    messages = session.get("messages", [])[-8:]
    lines = []
    for msg in messages:
        role = msg.get("role", "")
        content = msg.get("content", "").strip()
        if content:
            lines.append(f"{role.upper()}: {content}")
    return "\n".join(lines).strip()


def build_prompt(user_message: str, retrieved: List[Dict[str, Any]], session_context: str) -> List[Dict[str, str]]:
    context_blocks = []
    for i, item in enumerate(retrieved, start=1):
        meta = item["metadata"] or {}
        source_name = meta.get("source_name", "unknown")
        file_type = meta.get("file_type", "unknown")
        chunk_index = meta.get("chunk_index", "")
        context_blocks.append(
            f"[{i}] Source: {source_name} | Type: {file_type} | Chunk: {chunk_index}\n{item['text']}"
        )

    context_text = "\n\n".join(context_blocks) if context_blocks else "No context retrieved."

    system_prompt = (
        "You are a banking support assistant.\n"
        "Answer ONLY using the provided context and the conversation history.\n"
        "If the answer is not present in the context, say that you could not find enough information in the uploaded documents.\n"
        "Do not invent facts.\n"
        "Be concise, professional, helpful, and grounded.\n"
        "When the user asks a follow-up question, use the conversation history to resolve references like 'it', 'that', or 'those'."
    )

    user_prompt = (
        f"Conversation history:\n{session_context if session_context else 'None'}\n\n"
        f"Retrieved context:\n{context_text}\n\n"
        f"User question:\n{user_message}\n\n"
        "Return a direct answer. If needed, mention the relevant source number(s) from the context."
    )

    return [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_prompt},
    ]


def fallback_answer(user_message: str, retrieved: List[Dict[str, Any]]) -> str:
    if not retrieved:
        return "I could not find enough information in the uploaded documents."
    best = retrieved[0]["text"].strip()
    snippet = best[:600]
    if len(best) > 600:
        snippet += "..."
    return (
        "I could not access the LLM service right now, but here is the most relevant grounded excerpt from the documents:\n\n"
        f"{snippet}"
    )


def call_llm(messages: List[Dict[str, str]]) -> str:
    if llm_client is None:
        raise RuntimeError("LLM client is not configured.")

    response = llm_client.chat.completions.create(
        model=LLM_MODEL,
        messages=messages,
        temperature=0.2,
    )
    return response.choices[0].message.content.strip()


def estimate_confidence(best_score: float, retrieved: List[Dict[str, Any]]) -> float:
    if not retrieved:
        return 0.0
    scores = [float(x.get("score", 0.0)) for x in retrieved[:3]]
    avg = sum(scores) / max(1, len(scores))
    conf = (best_score * 0.65) + (avg * 0.35)
    return round(max(0.0, min(1.0, conf)), 4)


def ingest_file(upload_file: UploadFile) -> Dict[str, Any]:
    if not upload_file.filename:
        raise HTTPException(status_code=400, detail="Missing filename")

    filename = safe_filename(upload_file.filename)
    ext = Path(filename).suffix.lower()

    if ext not in {".pdf", ".txt", ".docx"}:
        raise HTTPException(status_code=400, detail="Only PDF, TXT, and DOCX files are supported")

    file_id = str(uuid.uuid4())
    stored_name = f"{file_id}_{filename}"
    stored_path = UPLOAD_DIR / stored_name

    contents = upload_file.file.read()
    if not contents:
        raise HTTPException(status_code=400, detail=f"File '{filename}' is empty")

    with stored_path.open("wb") as f:
        f.write(contents)

    file_hash = file_sha256(stored_path)
    text = extract_text(stored_path)
    if not text or len(text.strip()) < 20:
        raise HTTPException(status_code=400, detail=f"Could not extract enough text from '{filename}'")

    chunks = chunk_text(text)
    total_chunks = add_chunks_to_vector_db(
        chunks=chunks,
        source_name=filename,
        file_hash=file_hash,
        file_path=str(stored_path),
        file_type=ext.replace(".", ""),
    )

    return {
        "file_id": file_id,
        "filename": filename,
        "stored_path": str(stored_path),
        "file_hash": file_hash,
        "chunks": total_chunks,
        "uploaded_at": now_iso(),
    }


